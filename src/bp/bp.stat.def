// Fired in ft.cc when a BTB hit pulls the recovery cycle earlier than it would
// otherwise be.  BTB_L1_HIT_SCHED_EARLY_RECOVERY: L1 BTB hit in the
// l0_wrong+main_correct case, allowing recovery at BTB_L1_LATENCY instead of
// BP_MAIN_LATENCY.  BTB_MAIN_HIT_TIGHT_RECOVERY: main BTB hit in the
// l0_correct+main_wrong case when BTB_MAIN_LATENCY > BP_MAIN_LATENCY.
DEF_STAT(  BTB_L1_HIT_SCHED_EARLY_RECOVERY,  COUNT, NO_RATIO )
DEF_STAT(  BTB_MAIN_HIT_TIGHT_RECOVERY,       COUNT, NO_RATIO )
