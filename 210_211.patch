commit af21095dee334404af9e2d0cdb8366c8905f8038
Author: Mingsheng Xu <mxu61@ucsc.edu>
Date:   Fri Mar 1 17:23:48 2024 -0800

    Bugfix: condition how the map stage consume instructions from icache stage
    
    Previously the consumption was unconditioned. However, not all instructions from the icache stage are available for use by the map stage: those fetched from the uop can (bypassing both decoding and the empty uop queue), while the others cannot. This bug skipped the decode stage for all instructions and modeled the delay incorrectly.
    
    The bugfix limits the icache consumption to uop-fetched instructions only.

diff --git a/src/cmp_model.c b/src/cmp_model.c
index 4345970..c8fe844 100644
--- a/src/cmp_model.c
+++ b/src/cmp_model.c
@@ -227,9 +227,10 @@ void cmp_cores(void) {
       // Map stage can get ops from either the uop queue following the uop cache
       // or the decoder.
       Stage_Data* map_stage_uop_cache_src = get_uop_queue_stage_length() > 0 ? uop_queue_stage_get_latest_sd() : &ic->sd;
+      Flag uopq_src_is_icache = get_uop_queue_stage_length() > 0 ? FALSE : TRUE;
       // doesnt work: decode_stage_process_op must be called once per op. For uop cache, one cycle after fetch.
       // I can add a flag: decode_cycle (cycle decoded).
-      update_map_stage(dec->last_sd, map_stage_uop_cache_src);
+      update_map_stage(dec->last_sd, map_stage_uop_cache_src, uopq_src_is_icache);
       update_uop_queue_stage(&ic->sd);
       update_decode_stage(&ic->sd);
       update_decoupled_fe();
