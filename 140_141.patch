       DEBUG(uop_cache_proc_id, "UOC %s. ft_start=0x%llx, ft_length=%lld\n",
             uoc_data ? "hit" : "miss", ft_info.static_info.start, ft_info.static_info.length);
       if (!uoc_data) {
