-
-  if(pb_data->pb_ident == PB_ICACHE) {
-    if(PACKET_BREAK_ON_FUS) {
-      char *prev, *curr, buf[50];
-      uns32 type = 0;
-      int   i;
-
-      memset(pb_data->fu_info, 0, sizeof(Fu) * PB_NUM_FU_TYPES);
