   Uop_Cache_Data* uoc_data = NULL;
   Addr lookup_addr = ft_info.static_info.start;
-  int buffer_index = 0;
   do {
     uoc_data = uop_cache_lookup_line(lookup_addr, ft_info, TRUE);
-    if (buffer_index == 0) {
